            <div class="glass-card p-6 text-center border-l-4 border-emerald-500">
                <p class="text-[10px] font-bold text-gray-500 uppercase">Total Revenue</p>
                <h3 class="text-2xl font-black text-emerald-400">₹${totalRevenue}</h3>
            </div>
        </div>

        <!-- Quick Actions (iPhone Style Icons) -->
        <div class="grid grid-cols-4 gap-3 mb-8">
            <div onclick="showAddStudent()" class="glass-card aspect-square flex flex-col items-center justify-center cursor-pointer hover:bg-indigo-600 group transition-all">
                <i class="fas fa-user-plus text-indigo-400 group-hover:text-white mb-2"></i>
                <span class="text-[8px] font-bold uppercase">Add</span>
            </div>
            <div onclick="showSeatMatrix()" class="glass-card aspect-square flex flex-col items-center justify-center cursor-pointer hover:bg-amber-600 group transition-all">
                <i class="fas fa-th text-amber-400 group-hover:text-white mb-2"></i>
                <span class="text-[8px] font-bold uppercase">Seats</span>
            </div>
            <div onclick="renderAdminDashboard()" class="glass-card aspect-square flex flex-col items-center justify-center cursor-pointer hover:bg-emerald-600 group transition-all">
                <i class="fas fa-wallet text-emerald-400 group-hover:text-white mb-2"></i>
                <span class="text-[8px] font-bold uppercase">Fees</span>
            </div>
            <div onclick="showAttendanceLogs()" class="glass-card aspect-square flex flex-col items-center justify-center cursor-pointer hover:bg-blue-600 group transition-all">
                <i class="fas fa-clipboard-list text-blue-400 group-hover:text-white mb-2"></i>
                <span class="text-[8px] font-bold uppercase">Logs</span>
            </div>
        </div>

        <!-- Student List -->
        <div id="dynamicSection" class="space-y-4">
            <h4 class="text-xs font-black uppercase text-gray-500 tracking-widest px-2">Registered Students</h4>
            ${students.map(s => `
                <div class="glass-card p-5">
                    <div class="flex justify-between items-start">
                        <div>
                            <h4 class="font-black italic text-white">${s.name}</h4>
