// Data aur State Management
let students = [
    { id: 'LIB-1001', name: 'Jitendra Meghwal', seat: '12', phone: '9462376154', amount: '3000', status: 'Pending' },
    { id: 'LIB-1002', name: 'Vikas Sankhla', seat: '05', phone: '9588811700', amount: '2500', status: 'Paid' }
];

let attendance = [];
let totalSeats = 50;
const whatsappNo = "7023909061";

// Login Logic
window.handleLogin = () => {
    const user = document.getElementById('username').value;
    const pass = document.getElementById('password').value;
    
    // Admin Login
    if(user === 'admin' && pass === '1234') {
        document.getElementById('loginScreen').classList.add('hidden');
        document.getElementById('dashboardMain').classList.remove('hidden');
        renderAdminDashboard();
    } 
    // Student Login (Checking via Unique ID)
    else if(students.find(s => s.id === user)) {
        const student = students.find(s => s.id === user);
        document.getElementById('loginScreen').classList.add('hidden');
        document.getElementById('dashboardMain').classList.remove('hidden');
        renderStudentDashboard(student);
    }
    else {
        document.getElementById('loginError').classList.remove('hidden');
    }
};

// Admin Dashboard Render
