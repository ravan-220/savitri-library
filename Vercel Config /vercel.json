                <i class="fas fa-user-graduate text-3xl"></i>
            </div>
            <h2 class="text-2xl font-black italic uppercase text-white">${student.name}</h2>
            <p class="text-[10px] text-indigo-400 font-bold tracking-widest uppercase mt-1">Student Portal | Seat ${student.seat}</p>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-6">
            <button onclick="markAttendance('${student.id}')" class="glass-card aspect-square flex flex-col items-center justify-center gap-3 hover:bg-indigo-600 group transition-all">
                <i class="fas fa-calendar-check text-2xl text-indigo-400 group-hover:text-white"></i>
                <span class="text-[10px] font-black uppercase tracking-widest">Attendance</span>
            </button>
            <button onclick="alert('System: Contact Admin for Payment QR')" class="glass-card aspect-square flex flex-col items-center justify-center gap-3 hover:bg-emerald-600 group transition-all">
                <i class="fas fa-credit-card text-2xl text-emerald-400 group-hover:text-white"></i>
                <span class="text-[10px] font-black uppercase tracking-widest">Pay Fees</span>
            </button>
        </div>

        <button onclick="window.open('https://wa.me/91${whatsappNo}')" class="w-full bg-[#128c7e] p-6 rounded-[2rem] flex items-center justify-between text-white shadow-2xl active:scale-95 transition-all">
            <div class="flex items-center gap-4">
                <i class="fab fa-whatsapp text-2xl"></i>
                <div class="text-left">
                    <p class="font-black italic uppercase text-sm leading-none">Support Desk</p>
                    <p class="text-[9px] font-bold opacity-70 uppercase tracking-widest mt-1">Chat with Rahul Sir</p>
                </div>
            </div>
            <i class="fas fa-chevron-right text-xs opacity-50"></i>
