};

// Feature: Add Student with Unique ID
window.showAddStudent = () => {
    const section = document.getElementById('dynamicSection');
    const newId = "LIB-" + Math.floor(1000 + Math.random() * 9000);
    section.innerHTML = `
        <div class="glass-card p-6 animate-in slide-in-from-bottom duration-300">
            <h3 class="text-lg font-black italic uppercase mb-4">New Admission</h3>
            <div class="space-y-4">
                <input type="text" id="newName" placeholder="Student Name" class="w-full">
                <input type="text" id="newPhone" placeholder="Phone Number" class="w-full">
                <input type="number" id="newSeat" placeholder="Seat Number (1-50)" class="w-full">
                <input type="number" id="newAmount" placeholder="Monthly Fee" class="w-full">
                <div class="p-4 bg-indigo-500/5 border border-indigo-500/20 rounded-xl">
                    <p class="text-[9px] font-bold text-indigo-400 uppercase mb-1">Generated ID</p>
                    <p class="text-xl font-black text-white">${newId}</p>
                </div>
                <button onclick="saveStudent('${newId}')" class="btn-primary w-full py-4 mt-2">Confirm Registration</button>
                <button onclick="renderAdminDashboard()" class="w-full text-gray-500 text-xs font-bold uppercase py-2">Cancel</button>
            </div>
        </div>
    `;
};

window.saveStudent = (id) => {
    const name = document.getElementById('newName').value;
    const phone = document.getElementById('newPhone').value;
    const seat = document.getElementById('newSeat').value;
    const amount = document.getElementById('newAmount').value;

    if(!name || !phone || !seat) return alert('Sari details bharein!');

    students.push({ id, name, phone, seat, amount, status: 'Pending' });
    alert('Student Added Successfully! ID: ' + id);
    renderAdminDashboard();
};

// Feature: Seat Matrix
window.showSeatMatrix = () => {
    const section = document.getElementById('dynamicSection');
    let seatHtml = '<div class="grid grid-cols-5 gap-3">';
    
    for(let i=1; i<=totalSeats; i++) {
        const occupied = students.find(s => Number(s.seat) === i);
        seatHtml += `
            <div class="aspect-square rounded-xl border-2 flex flex-col items-center justify-center text-[10px] font-bold
                ${occupied ? 'bg-rose-500/10 border-rose-500/30 text-rose-400' : 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400'}">
                ${i}
                <span class="text-[7px] uppercase opacity-60">${occupied ? 'Full' : 'Open'}</span>
            </div>
        `;
    }
    seatHtml += '</div><button onclick="renderAdminDashboard()" class="btn-primary w-full py-4 mt-6">Back to Dashboard</button>';
    section.innerHTML = `<h3 class="text-lg font-black italic uppercase mb-4 px-2">Seat Matrix</h3>` + seatHtml;
};

