                            </p>
                        </div>
                        <span class="id-badge ${s.status === 'Paid' ? 'text-emerald-400 border-emerald-500/30' : 'text-rose-400 border-rose-500/30'}">${s.status}</span>
                    </div>
                    <div class="flex gap-2 mt-4">
                        <button onclick="window.open('https://wa.me/91${s.phone}')" class="flex-1 bg-emerald-600/10 text-emerald-500 py-3 rounded-xl text-[9px] font-black uppercase">Message</button>
                        <button onclick="removeStudent('${s.id}')" class="bg-rose-600/10 text-rose-500 px-4 py-3 rounded-xl text-[9px] font-black uppercase">Remove</button>
